generator client {
  provider     = "prisma-client"
  output       = "../src/generate/database/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

//enum
enum RoleType {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

enum EmploymentLevel {
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  LEAVE
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PositionName {
  ENGINEERING_MANAGER
  PRODUCT_MANAGER
  SCRUM_MASTER
  PROJECT_MANAGER

  FRONTEND_DEVELOPER
  BACKEND_DEVELOPER
  FULLSTACK_DEVELOPER
  DEVOPT_ENGINEERING
  QA_ENGINEER
  QA_AUTOMATE_ENGINEER
  SOFTWARE_TESTER
  UX_DESIGNER
  UI_DESIGNER
  UX_UI_DESIGNER
  SYSTEM_ADMINISTRATOR
  CLOUD_ENGINEERING
  DATABASE_ADMINISTRATOR
}

// POSITIONS
model Position {
  id           String       @id @default(uuid())
  name         PositionName @unique
  allowed_role RoleType
  users        User[]

  @@map("positions")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique @db.VarChar(150)
  password  String    @db.VarChar(255)
  firstName String    @map("first_name") @db.VarChar(100)
  lastName  String    @map("last_name") @db.VarChar(100)
  birthDate DateTime? @map("birth_date") @db.Date

  profileImageUrl      String? @map("profile_image_url")
  profileImagePublicId String? @map("profile_image_public_id")

  roleType RoleType @map("role_type")

  positionId String   @map("position_id")
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  level  EmploymentLevel
  status EmploymentStatus @default(ACTIVE)

  createdById  String? @map("create_by_id")
  createdBy    User?   @relation("UserCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdUsers User[]  @relation("UserCreator")

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  assignedTasks   Task[]    @relation("TaskAssignee")
  createdTasks    Task[]    @relation("TaskCreator")
  createdProjects Project[] @relation("ProjectCreator")
  comments        Comment[]

  @@index([positionId])
  @@index([createdById])
  @@map("users")
}

model Project {
  id          String        @id @default(uuid())
  title       String
  description String
  status      ProjectStatus @default(ACTIVE)

  createdById String @map("created_by_id")
  createdBy   User   @relation("ProjectCreator", fields: [createdById], references: [id])

  tasks     Task[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([createdById])
  @@map("projects")
}

model Task {
  id String @id @default(uuid())

  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assignToId String @map("assign_to_id")
  assignTo   User   @relation("TaskAssignee", fields: [assignToId], references: [id], onDelete: Cascade)

  createdById String @map("crated_by_id")
  createdBy   User   @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

  title       String
  description String?

  priority TaskPriority
  status   TaskStatus

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  comments  Comment[]

  @@index([projectId])
  @@index([assignToId])
  @@index([createdById])
  @@map("tasks")
}

model Comment {
  id String @id @default(uuid())

  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  content String

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([taskId])
  @@index([userId])
  @@map("comments")
}
