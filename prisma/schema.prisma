generator client {
  provider     = "prisma-client"
  output       = "../src/database/generate/database/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

//enum
enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RoleType {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

enum EmploymentLevel {
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  LEAVE
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

enum ProjectMemberRole {
  ADMIN
  MEMBER
  VIEWER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PositionName {
  ENGINEERING_MANAGER
  PRODUCT_MANAGER
  SCRUM_MASTER
  PROJECT_MANAGER

  FRONTEND_DEVELOPER
  BACKEND_DEVELOPER
  FULLSTACK_DEVELOPER
  DEVOPT_ENGINEERING
  QA_ENGINEER
  QA_AUTOMATE_ENGINEER
  SOFTWARE_TESTER
  UX_DESIGNER
  UI_DESIGNER
  UX_UI_DESIGNER
  SYSTEM_ADMINISTRATOR
  CLOUD_ENGINEERING
  DATABASE_ADMINISTRATOR
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique @db.VarChar(150)
  password  String    @db.VarChar(255)
  firstName String    @map("first_name") @db.VarChar(100)
  lastName  String    @map("last_name") @db.VarChar(100)
  birthDate DateTime? @map("birth_date") @db.Date
  gender    Gender

  profileImageUrl      String? @map("profile_image_url")
  profileImagePublicId String? @map("profile_image_public_id")

  roleType RoleType @default(EMPLOYEE) @map("role_type")

  position PositionName

  level  EmploymentLevel  @default(JUNIOR)
  status EmploymentStatus @default(ACTIVE)

  createdById  String? @map("created_by_id")
  createdBy    User?   @relation("UserCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[]  @relation("UserCreator")

  createdProjects Project[]       @relation("ProjectCreator")
  assignedTasks   Task[]          @relation("TaskAssignee")
  createdTasks    Task[]          @relation("TaskCreator")
  comments        Comment[]
  projectMembers  ProjectMember[]

  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([createdById])
  @@map("users")
}

model Project {
  id          String        @id @default(uuid())
  title       String
  description String
  status      ProjectStatus @default(ACTIVE)

  dueDate DateTime? @map("due_date") @db.Timestamptz()

  createdById String @map("created_by_id")
  createdBy   User   @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Cascade)

  tasks          Task[]
  projectMembers ProjectMember[]

  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([createdById])
  @@map("projects")
}

model ProjectMember {
  id String @id @default(uuid())

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role      ProjectMemberRole @default(MEMBER)
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

model Task {
  id String @id @default(uuid())

  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assignToId String @map("assign_to_id")
  assignTo   User   @relation("TaskAssignee", fields: [assignToId], references: [id], onDelete: Cascade)

  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  createdById String @map("created_by_id")
  createdBy   User   @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

  title       String
  description String?

  priority TaskPriority @default(MEDIUM)
  status   TaskStatus   @default(TODO)
  comments Comment[]

  dueDate DateTime? @map("due_date") @db.Timestamptz()

  isPersonal Boolean @default(false) @map("is_personal")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([projectId])
  @@index([assignToId])
  @@index([createdById])
  @@index([deletedAt])
  @@map("tasks")
}

model Comment {
  id String @id @default(uuid())

  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  content String

  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([taskId])
  @@index([userId])
  @@map("comments")
}
